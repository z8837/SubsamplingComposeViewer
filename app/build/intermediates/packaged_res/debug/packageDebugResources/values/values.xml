<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="app_name">Subsampling Viewer</string>
    <string name="select_image">이미지 선택</string>
    <string name="viewer_empty_hint">선택한 이미지는 전체 화면으로 표시됩니다.</string>
    <style name="Theme.SubsamplingComposeViewer" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
    <declare-styleable name="SubsamplingScaleImageView">
        <attr format="reference" name="src"/>
        <attr format="string" name="assetName"/>
        <attr format="boolean" name="panEnabled"/>
        <attr format="boolean" name="zoomEnabled"/>
        <attr format="boolean" name="quickScaleEnabled"/>
        <attr format="color" name="tileBackgroundColor"/>
    </declare-styleable>
</resources>